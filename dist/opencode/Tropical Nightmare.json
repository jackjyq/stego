{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#000000",
    "red": "#ff5a66",
    "green": "#65d24b",
    "yellow": "#f2ae02",
    "blue": "#5394ff",
    "magenta": "#d16ce8",
    "cyan": "#02ced6",
    "white": "#e0e0e0",
    "background": "#121212",
    "foreground": "#e0e0e0",
    "hint": "#a0a0a0",
    "cursor": "#e0e0e0",
    "selection": "#264f78",
    "darkBgAlt": "#010409",
    "darkBgPanel": "#161b22",
    "lightBgAlt": "#f6f8fa",
    "lightBgPanel": "#f0f3f6"
  },
  "theme": {
    "primary": "blue",
    "secondary": "magenta",
    "accent": "cyan",
    "error": "red",
    "warning": "yellow",
    "success": "green",
    "info": "cyan",
    "text": "foreground",
    "textMuted": "hint",
    "background": "background",
    "backgroundPanel": {
      "dark": "darkBgAlt",
      "light": "lightBgAlt"
    },
    "backgroundElement": {
      "dark": "darkBgPanel",
      "light": "lightBgPanel"
    },
    "border": {
      "dark": "#30363d",
      "light": "#d0d7de"
    },
    "borderActive": "blue",
    "borderSubtle": {
      "dark": "#21262d",
      "light": "#d8dee4"
    },
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": "hint",
    "diffHunkHeader": "blue",
    "diffHighlightAdded": {
      "dark": "#3fb950",
      "light": "#1a7f37"
    },
    "diffHighlightRemoved": {
      "dark": "#f85149",
      "light": "#cf222e"
    },
    "diffAddedBg": {
      "dark": "#033a16",
      "light": "#dafbe1"
    },
    "diffRemovedBg": {
      "dark": "#67060c",
      "light": "#ffebe9"
    },
    "diffContextBg": {
      "dark": "darkBgAlt",
      "light": "lightBgAlt"
    },
    "diffLineNumber": {
      "dark": "#484f58",
      "light": "#afb8c1"
    },
    "diffAddedLineNumberBg": {
      "dark": "#033a16",
      "light": "#dafbe1"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#67060c",
      "light": "#ffebe9"
    },
    "markdownText": "foreground",
    "markdownHeading": "magenta",
    "markdownLink": "hint",
    "markdownLinkText": "blue",
    "markdownCode": "hint",
    "markdownBlockQuote": "hint",
    "markdownEmph": "foreground",
    "markdownStrong": "foreground",
      "markdownHorizontalRule": {
      "dark": "#30363d",
      "light": "#d0d7de"
    },
    "markdownListItem": "yellow",
    "markdownListEnumeration": "yellow",
    "markdownImage": "hint",
    "markdownImageText": "blue",
    "markdownCodeBlock": "hint",
    "syntaxComment": "hint",
    "syntaxKeyword": "red",
    "syntaxFunction": "green",
    "syntaxVariable": "foreground",
    "syntaxString": "yellow",
    "syntaxNumber": "magenta",
    "syntaxType": "green",
    "syntaxOperator": "red",
    "syntaxPunctuation": "foreground"
  }
}
