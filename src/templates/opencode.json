{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#{{ Ansi_0_Color.hex }}",
    "red": "#{{ Ansi_1_Color.hex }}",
    "green": "#{{ Ansi_2_Color.hex }}",
    "yellow": "#{{ Ansi_3_Color.hex }}",
    "blue": "#{{ Ansi_4_Color.hex }}",
    "magenta": "#{{ Ansi_5_Color.hex }}",
    "cyan": "#{{ Ansi_6_Color.hex }}",
    "white": "#{{ Ansi_7_Color.hex }}",
    "background": "#{{ Background_Color.hex }}",
    "foreground": "#{{ Foreground_Color.hex }}",
    "hint": "#{{ Hint_Text_Color.hex }}",
    "cursor": "#{{ Cursor_Color.hex }}",
    "selection": "#{{ Selection_Color.hex }}",
    "darkBgAlt": "#010409",
    "darkBgPanel": "#161b22",
    "lightBgAlt": "#f6f8fa",
    "lightBgPanel": "#f0f3f6"
  },
  "theme": {
    "primary": "blue",
    "secondary": "magenta",
    "accent": "cyan",
    "error": "red",
    "warning": "yellow",
    "success": "green",
    "info": "cyan",
    "text": "foreground",
    "textMuted": "hint",
    "background": "background",
    "backgroundPanel": {
      "dark": "darkBgAlt",
      "light": "lightBgAlt"
    },
    "backgroundElement": {
      "dark": "darkBgPanel",
      "light": "lightBgPanel"
    },
    "border": {
      "dark": "#30363d",
      "light": "#d0d7de"
    },
    "borderActive": "blue",
    "borderSubtle": {
      "dark": "#21262d",
      "light": "#d8dee4"
    },
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": "hint",
    "diffHunkHeader": "blue",
    "diffHighlightAdded": {
      "dark": "#3fb950",
      "light": "#1a7f37"
    },
    "diffHighlightRemoved": {
      "dark": "#f85149",
      "light": "#cf222e"
    },
    "diffAddedBg": {
      "dark": "#033a16",
      "light": "#dafbe1"
    },
    "diffRemovedBg": {
      "dark": "#67060c",
      "light": "#ffebe9"
    },
    "diffContextBg": {
      "dark": "darkBgAlt",
      "light": "lightBgAlt"
    },
    "diffLineNumber": {
      "dark": "#484f58",
      "light": "#afb8c1"
    },
    "diffAddedLineNumberBg": {
      "dark": "#033a16",
      "light": "#dafbe1"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#67060c",
      "light": "#ffebe9"
    },
    "markdownText": "foreground",
    "markdownHeading": "magenta",
    "markdownLink": "hint",
    "markdownLinkText": "blue",
    "markdownCode": "hint",
    "markdownBlockQuote": "hint",
    "markdownEmph": "foreground",
    "markdownStrong": "foreground",
      "markdownHorizontalRule": {
      "dark": "#30363d",
      "light": "#d0d7de"
    },
    "markdownListItem": "yellow",
    "markdownListEnumeration": "yellow",
    "markdownImage": "hint",
    "markdownImageText": "blue",
    "markdownCodeBlock": "hint",
    "syntaxComment": "hint",
    "syntaxKeyword": "red",
    "syntaxFunction": "green",
    "syntaxVariable": "foreground",
    "syntaxString": "yellow",
    "syntaxNumber": "magenta",
    "syntaxType": "green",
    "syntaxOperator": "red",
    "syntaxPunctuation": "foreground"
  }
}
